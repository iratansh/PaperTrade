# Database Configuration
# Docker Postgres is mapped to host port 5433 (avoids colliding with a local Postgres on 5432)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=papertrade
DB_USER=postgres
DB_PASSWORD=postgres

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Market data providers
FINNHUB_API_KEY=your_finnhub_api_key_here
TWELVE_DATA_API_KEY=your_twelve_data_api_key_here

# JWT Configuration
JWT_SECRET=your-super-secret-256-bit-key-change-this-in-production-please-make-it-long

# Server
SERVER_PORT=8080
